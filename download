import React from "react";
import { Shield, Lock, EyeOff, Trash2, Server, Globe2, Cpu, CheckCircle2 } from "lucide-react";
import { Language, TRANSLATIONS, SecurityConfig } from "../types";

interface SecurityConsoleProps {
  language: Language;
  config: SecurityConfig;
  onUpdateConfig: (config: SecurityConfig) => void;
}

export default function SecurityConsole({ language, config, onUpdateConfig }: SecurityConsoleProps) {
  const t = TRANSLATIONS[language];

  const handleToggleMasking = () => {
    onUpdateConfig({ ...config, dataMaskingEnabled: !config.dataMaskingEnabled });
  };

  const handleToggleCleanup = () => {
    onUpdateConfig({ ...config, autoPIICleanup: !config.autoPIICleanup });
  };

  const handleRegionChange = (region: string) => {
    onUpdateConfig({ ...config, dataRegion: region });
  };

  return (
    <div id="security-panel" className="space-y-6">
      
      {/* Title block */}
      <div>
        <h2 className="text-xl font-bold text-white tracking-tight flex items-center gap-2">
          <Shield className="w-5 h-5 text-indigo-400" />
          {t.securityAndRodoConfig}
        </h2>
        <p className="text-xs text-gray-400">
          {language === "pl" ? "Zarządzanie bezpieczeństwem danych, retencją logów oraz automatyczną anonimizacją RODO." : "Manage corporate support encryption, client-side obfuscation and GDPR compliance protocols."}
        </p>
      </div>

      <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        {/* Settings Board Col - 2 cols */}
        <div className="lg:col-span-2 space-y-4">
          
          {/* Item 1: Masking */}
          <div className="bg-[#16191f] border border-white/5 rounded-xl p-5 shadow-xl flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div className="flex-1">
              <div className="flex items-center gap-2 mb-1">
                <EyeOff className="w-4.5 h-4.5 text-indigo-400" />
                <h4 className="font-bold text-white text-sm">{t.dataMaskingTitle}</h4>
              </div>
              <p className="text-[11px] text-gray-400 leading-relaxed">
                {t.dataMaskingDesc}
              </p>
            </div>
            
            <button
              onClick={handleToggleMasking}
              className={`w-14 h-7 rounded-full transition-colors relative cursor-pointer ${
                config.dataMaskingEnabled ? "bg-indigo-600" : "bg-white/5"
              }`}
            >
              <span className={`absolute top-1 left-1 bg-white w-5 h-5 rounded-full shadow-md transition-transform ${
                config.dataMaskingEnabled ? "translate-x-7" : "translate-x-0"
              }`} />
            </button>
          </div>

          {/* Item 2: PII Scrub */}
          <div className="bg-[#16191f] border border-white/5 rounded-xl p-5 shadow-xl flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div className="flex-1">
              <div className="flex items-center gap-2 mb-1">
                <Trash2 className="w-4.5 h-4.5 text-indigo-400" />
                <h4 className="font-bold text-white text-sm">{t.autoPIITitle}</h4>
              </div>
              <p className="text-[11px] text-gray-400 leading-relaxed">
                {t.autoPIIDesc}
              </p>
            </div>

            <button
              onClick={handleToggleCleanup}
              className={`w-14 h-7 rounded-full transition-colors relative cursor-pointer ${
                config.autoPIICleanup ? "bg-indigo-600" : "bg-white/5"
              }`}
            >
              <span className={`absolute top-1 left-1 bg-white w-5 h-5 rounded-full shadow-md transition-transform ${
                config.autoPIICleanup ? "translate-x-7" : "translate-x-0"
              }`} />
            </button>
          </div>

          {/* Item 3: Parameters sliders */}
          <div className="bg-[#16191f] border border-white/5 rounded-xl p-5 shadow-xl grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label className="block text-gray-400 text-xs mb-1 font-semibold uppercase tracking-wider">
                {t.retentionDaysTitle}
              </label>
              <div className="flex items-center gap-4 mt-2">
                <input
                  type="range"
                  min="1"
                  max="90"
                  value={config.retentionDays}
                  onChange={(e) => onUpdateConfig({ ...config, retentionDays: parseInt(e.target.value) })}
                  className="flex-1 h-1 bg-[#2a2d35] rounded-lg appearance-none cursor-pointer accent-indigo-500"
                />
                <span className="text-white text-sm font-bold bg-[#0f1115] px-2.5 py-1 border border-white/5 rounded">
                  {config.retentionDays}
                </span>
              </div>
              <span className="text-[10px] text-gray-500 block mt-1">
                {language === "pl" ? "Logi są całkowicie usuwane po tym okresie." : "Log files completely purged after deadline."}
              </span>
            </div>

            <div>
              <label className="block text-gray-400 text-xs mb-1 font-semibold uppercase tracking-wider">
                {t.sessionTimeoutTitle}
              </label>
              <div className="flex items-center gap-4 mt-2">
                <input
                  type="range"
                  min="5"
                  max="120"
                  value={config.sessionTimeoutMinutes}
                  onChange={(e) => onUpdateConfig({ ...config, sessionTimeoutMinutes: parseInt(e.target.value) })}
                  className="flex-1 h-1 bg-[#2a2d35] rounded-lg appearance-none cursor-pointer accent-indigo-500"
                />
                <span className="text-white text-sm font-bold bg-[#0f1115] px-2.5 py-1 border border-white/5 rounded">
                  {config.sessionTimeoutMinutes} min
                </span>
              </div>
              <span className="text-[10px] text-gray-500 block mt-1">
                {language === "pl" ? "Czas braku aktwności do rozłączenia klienta." : "Client disconnect threshold upon idle status."}
              </span>
            </div>
          </div>

          {/* Item 3.5: AI Personality & Tone Tuning */}
          <div className="bg-[#16191f] border border-[#4f46e5]/20 rounded-xl p-5 shadow-xl space-y-4">
            <div className="flex items-center gap-2 mb-1">
              <Cpu className="w-4.5 h-4.5 text-indigo-400 animate-pulse" />
              <h4 className="font-bold text-white text-sm">
                {language === "pl" ? "Regulacja i ton charakteru Copilot AI" : "AI Copilot Demeanor & Response Regulations"}
              </h4>
            </div>
            
            <p className="text-[11px] text-gray-400 leading-relaxed">
              {language === "pl"
                ? "Dostosuj zachowanie, ton językowy oraz kreatywność silnika chatbotów. Wybór wpływa natychmiastowo na styl budowanych zdań przez model Gemini."
                : "Calibrate chatbot demeanor, dialect styles, and lexical depth. These settings are dynamically dispatched to Gemini generative blocks."}
            </p>

            <div className="grid grid-cols-1 md:grid-cols-2 gap-4 pt-2">
              <div>
                <span className="block text-gray-400 text-[10px] uppercase font-semibold tracking-wider mb-2">
                  {language === "pl" ? "Ton Głosu Asystenta" : "Assistant Tone Mode"}
                </span>
                <div className="flex bg-[#0f1115] p-1 rounded-lg border border-white/10 gap-1">
                  {[
                    { id: "polite", label: language === "pl" ? "Uprzejmy" : "Polite" },
                    { id: "concise", label: language === "pl" ? "Krótki" : "Concise" },
                    { id: "formal", label: language === "pl" ? "Formalny" : "Formal" }
                  ].map((btn) => (
                    <button
                      key={btn.id}
                      type="button"
                      onClick={() => onUpdateConfig({ ...config, aiTone: btn.id as any })}
                      className={`flex-1 text-center py-1 rounded text-xs font-semibold cursor-pointer transition-all ${
                        config.aiTone === btn.id
                          ? "bg-indigo-600 text-white"
                          : "text-gray-400 hover:text-white"
                      }`}
                    >
                      {btn.label}
                    </button>
                  ))}
                </div>
              </div>

              <div>
                <span className="block text-gray-400 text-[10px] uppercase font-semibold tracking-wider mb-2">
                  {language === "pl" ? "Kreatywność AI (Model Temperature)" : "AI Creativity (Model Temperature)"}
                </span>
                <div className="flex items-center gap-3">
                  <input
                    type="range"
                    min="0.1"
                    max="1.0"
                    step="0.1"
                    value={config.aiTemperature}
                    onChange={(e) => onUpdateConfig({ ...config, aiTemperature: parseFloat(e.target.value) })}
                    className="flex-1 h-1 bg-[#2a2d35] rounded-lg appearance-none cursor-pointer accent-indigo-500"
                  />
                  <span className="text-white text-xs font-mono font-bold bg-[#0f1115] px-2.5 py-1 border border-white/5 rounded">
                    {config.aiTemperature}
                  </span>
                </div>
                <span className="text-[9px] text-gray-500 block mt-1">
                  {language === "pl" 
                    ? "Niższe wartości do analiz technicznych, wyższe do naturalnej rozmowy." 
                    : "Low is accurate Technical support, high is customer relations support."}
                </span>
              </div>
            </div>
          </div>

          {/* Item 4: Region */}
          <div className="bg-[#16191f] border border-white/5 rounded-xl p-5 shadow-xl">
            <div className="flex items-center gap-2 mb-3">
              <Server className="w-4.5 h-4.5 text-indigo-400" />
              <h4 className="font-bold text-white text-sm">{t.dataStorageRegion}</h4>
            </div>
            
            <div className="grid grid-cols-1 sm:grid-cols-3 gap-3">
              {[
                { id: "eu_warsaw", label: "Polska (Warszawa) / Warsaw", ping: "8ms" },
                { id: "eu_frankfurt", label: "Niemcy (Frankfurt) / FRA", ping: "16ms" },
                { id: "us_oregon", label: "USA (Oregon) / Western US", ping: "110ms" }
              ].map((reg) => {
                const isSelected = reg.id === config.dataRegion;
                return (
                  <button
                    key={reg.id}
                    onClick={() => handleRegionChange(reg.id)}
                    className={`p-3 border rounded-xl text-left transition-all cursor-pointer ${
                      isSelected 
                        ? "bg-indigo-950/20 border-indigo-505 text-white" 
                        : "bg-white/5 border-white/10 text-gray-405 hover:border-[#4f46e5]/40"
                    }`}
                  >
                    <span className="text-xs font-bold block">{reg.label}</span>
                    <span className="text-[10px] text-gray-505 mt-1 block font-mono">Latency: {reg.ping}</span>
                  </button>
                );
              })}
            </div>
          </div>

        </div>

        {/* Security Summary Right - 1 col */}
        <div className="bg-[#16191f] border border-white/5 rounded-xl p-5 shadow-xl space-y-4 h-fit">
          <div className="pb-3 border-b border-white/5 flex items-center justify-between">
            <h4 className="font-semibold text-white text-xs uppercase tracking-wider">
              {t.gdprCompliantStatus}
            </h4>
            <CheckCircle2 className="w-5 h-5 text-indigo-400" />
          </div>

          <p className="text-[11.5px] text-gray-400 leading-relaxed">
            {language === "pl" 
              ? "Nasza platforma została zaprojektowana zgodnie z zasadą Privacy by Design. Dbamy o to, aby dane Twoich klientów były chronione na każdym etapie przetwarzania."
              : "Designed directly in accordance with Privacy by Design standards, safeguarding your visitors' credentials throughout continuous analysis cycles."}
          </p>

          <div className="space-y-3 font-medium text-xs border-t border-white/5 pt-4">
            <span className="text-gray-500 block text-[10px] uppercase font-bold tracking-wider mb-2">
              {t.activeSecurityProtocols}
            </span>
            
            <div className="flex items-center gap-2 text-gray-200">
              <span className="w-1.5 h-1.5 rounded-full bg-indigo-400 animate-pulse"></span>
              <span>{t.sslEncryption}</span>
            </div>

            <div className="flex items-center gap-2 text-gray-200">
              <span className="w-1.5 h-1.5 rounded-full bg-indigo-400 animate-pulse"></span>
              <span>AES-256 {language === "pl" ? "Szyfrowanie bazy danych" : "Database At-Rest Encryption"}</span>
            </div>

            <div className="flex items-center gap-2 text-gray-200">
              <span className="w-1.5 h-1.5 rounded-full bg-indigo-400 animate-pulse"></span>
              <span>{t.dataAnonymized}</span>
            </div>

            <div className="flex items-center gap-2 text-gray-200">
              <span className="w-1.5 h-1.5 rounded-full bg-indigo-400 animate-pulse"></span>
              <span>ISO 27001 / SOC 2 {language === "pl" ? "Standard Serwera" : "Server Standard Infrastructure"}</span>
            </div>
          </div>

          <div className="bg-[#0a0b0d] p-3 rounded-lg border border-white/5">
            <span className="text-[9px] text-gray-500 block uppercase font-bold">RODO Audit Hash</span>
            <span className="font-mono text-[9px] text-indigo-400 block truncate">
              sha256:7f426e828114cdb83e022091fbbaedfe9b...
            </span>
          </div>
        </div>

      </div>

    </div>
  );
}
