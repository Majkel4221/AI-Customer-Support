import React, { useState } from "react";
import { 
  Sparkles, 
  MessageSquare, 
  User, 
  Send, 
  CheckCircle, 
  AlertOctagon, 
  Smile, 
  UserCheck, 
  Power, 
  Languages, 
  ArrowRightLeft,
  Filter
} from "lucide-react";
import { Conversation, Message, Language, TRANSLATIONS, UrgencyType } from "../types";

interface LiveChatProps {
  language: Language;
  conversations: Conversation[];
  onSelectConversation: (id: string) => void;
  selectedConversationId: string | null;
  onUpdateConversation: (conv: Conversation) => void;
}

export default function LiveChat({
  language,
  conversations,
  onSelectConversation,
  selectedConversationId,
  onUpdateConversation,
}: LiveChatProps) {
  const [inputText, setInputText] = useState("");
  const [filterUrgency, setFilterUrgency] = useState<string>("all");
  const [filterStatus, setFilterStatus] = useState<string>("all");

  const t = TRANSLATIONS[language];

  const selectedConv = conversations.find(c => c.id === selectedConversationId) || null;

  const handleSendMessage = (e: React.FormEvent) => {
    e.preventDefault();
    if (!inputText.trim() || !selectedConv) return;

    // Append human-typed message
    const newMsg: Message = {
      id: "agent_msg_" + Math.random().toString(36).substr(2, 9),
      sender: "agent",
      text: inputText,
      timestamp: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
    };

    const updatedConv: Conversation = {
      ...selectedConv,
      messages: [...selectedConv.messages, newMsg],
      status: "active_agent", // Lock status to live agent to simulate manual takeover
      lastUpdated: new Date().toISOString(),
    };

    onUpdateConversation(updatedConv);
    setInputText("");
  };

  // Agent applies one of the AI sugestions
  const handleApplySuggestion = (suggestionText: string) => {
    setInputText(suggestionText);
  };

  // Quick state togglers
  const handleToggleTakeover = () => {
    if (!selectedConv) return;
    const nextStatus = selectedConv.status === "active_agent" ? "active_bot" : "active_agent";
    onUpdateConversation({
      ...selectedConv,
      status: nextStatus,
      lastUpdated: new Date().toISOString(),
    });
  };

  const handleToggleSolved = () => {
    if (!selectedConv) return;
    const nextStatus = selectedConv.status === "solved" ? "active_bot" : "solved";
    onUpdateConversation({
      ...selectedConv,
      status: nextStatus,
      lastUpdated: new Date().toISOString(),
    });
  };

  // Filtering helper
  const filteredConversations = conversations.filter(c => {
    const matchUrgency = filterUrgency === "all" || c.urgency === filterUrgency;
    const matchStatus = filterStatus === "all" || 
      (filterStatus === "active" && c.status !== "solved") ||
      (filterStatus === "solved" && c.status === "solved");
    return matchUrgency && matchStatus;
  });

  const getUrgencyBadgeColor = (urgency: UrgencyType) => {
    switch (urgency) {
      case "critical":
        return "bg-red-500/10 border-red-500/30 text-red-400 animate-pulse";
      case "high":
        return "bg-orange-500/10 border-orange-500/30 text-orange-400";
      case "medium":
        return "bg-amber-500/10 border-amber-500/30 text-amber-400";
      default:
        return "bg-emerald-500/10 border-emerald-500/30 text-emerald-400";
    }
  };

  const getUrgencyNamePlEn = (urgency: UrgencyType) => {
    const maps = {
      pl: { low: "Niska", medium: "Średnia", high: "Wysoka", critical: "Krytyczna" },
      en: { low: "Low", medium: "Medium", high: "High", critical: "Critical" },
    };
    return maps[language][urgency];
  };

  const getSentimentIcon = (sentiment?: string) => {
    switch (sentiment) {
      case "positive":
        return <span className="text-emerald-400 flex items-center gap-1">😊 {t.sentimentPositive}</span>;
      case "negative":
        return <span className="text-red-400 flex items-center gap-1">😠 {t.sentimentNegative}</span>;
      default:
        return <span className="text-slate-400 flex items-center gap-1">😐 {t.sentimentNeutral}</span>;
    }
  };

  return (
    <div id="live-chat-panel" className="grid grid-cols-1 lg:grid-cols-3 gap-6 h-[calc(100vh-12rem)] min-h-[500px]">
      
      {/* Sidebar - Chats List */}
      <div className="lg:col-span-1 bg-[#0f1115] border border-white/10 rounded-xl flex flex-col overflow-hidden">
        {/* Filter bar */}
        <div className="p-3 border-b border-white/10 bg-[#0a0b0d] flex flex-wrap gap-2 items-center justify-between">
          <div className="flex items-center gap-1.5 text-xs text-gray-300 font-semibold mb-1 w-full">
            <Filter className="w-3.5 h-3.5 text-indigo-400" />
            <span>Filtruj zgłoszenia</span>
          </div>
          
          <select
            value={filterUrgency}
            onChange={(e) => setFilterUrgency(e.target.value)}
            className="flex-1 min-w-[80px] text-[11px] bg-[#16191f] border border-white/10 rounded-md py-1 px-1.5 text-gray-350 focus:outline-none"
          >
            <option value="all">Prio: {language === "pl" ? "Wszystkie" : "All"}</option>
            <option value="low">Prio: {t.urgencyLow}</option>
            <option value="medium">Prio: {t.urgencyMedium}</option>
            <option value="high">Prio: {t.urgencyHigh}</option>
            <option value="critical">Prio: {t.urgencyCritical}</option>
          </select>

          <select
            value={filterStatus}
            onChange={(e) => setFilterStatus(e.target.value)}
            className="flex-1 min-w-[80px] text-[11px] bg-[#16191f] border border-white/10 rounded-md py-1 px-1.5 text-gray-350 focus:outline-none"
          >
            <option value="all">Status: {language === "pl" ? "Wszystkie" : "All"}</option>
            <option value="active">{language === "pl" ? "Aktywne" : "Active"}</option>
            <option value="solved">ROZWIĄZANE</option>
          </select>
        </div>

        {/* List flow */}
        <div className="flex-1 overflow-y-auto divide-y divide-white/5">
          {filteredConversations.length === 0 ? (
            <div className="p-8 text-center text-gray-400 text-xs">
              {t.noActiveChats}
            </div>
          ) : (
            filteredConversations.map((conv) => {
              const lastMsgObj = conv.messages[conv.messages.length - 1];
              const lastMsg = lastMsgObj ? lastMsgObj.text : "...";
              const isSelected = conv.id === selectedConversationId;

              return (
                <button
                  key={conv.id}
                  onClick={() => onSelectConversation(conv.id)}
                  className={`w-full text-left p-4 hover:bg-white/5 flex flex-col justify-between transition-colors cursor-pointer ${
                    isSelected ? "bg-white/5 border-r-2 border-indigo-500" : ""
                  }`}
                >
                  <div className="flex items-center justify-between w-full mb-1">
                    <span className="font-semibold text-xs text-white truncate max-w-[120px]">
                      {conv.userName}
                    </span>
                    <span className="text-[9px] text-gray-400 flex-shrink-0">
                      {lastMsgObj ? lastMsgObj.timestamp : ""}
                    </span>
                  </div>

                  <p className="text-[10px] text-gray-400 truncate mb-2 max-w-[200px]">
                    {lastMsg}
                  </p>

                  <div className="flex items-center gap-1.5 flex-wrap mt-1">
                    {/* Urgency Badge */}
                    <span className={`text-[9px] px-1.5 py-0.5 rounded border font-medium ${getUrgencyBadgeColor(conv.urgency)}`}>
                      {getUrgencyNamePlEn(conv.urgency)}
                    </span>

                    {/* Category */}
                    {conv.category && (
                      <span className="text-[9px] px-1.5 py-0.5 rounded border border-white/5 bg-[#16191f] text-gray-400">
                        {conv.category}
                      </span>
                    )}

                    {/* Status marker */}
                    <span className={`text-[8px] uppercase px-1.5 py-0.2 rounded font-bold border ${
                      conv.status === "solved" ? "bg-green-950/25 text-green-400 border-green-500/30" :
                      conv.status === "active_agent" ? "bg-indigo-950/20 text-indigo-400 border-indigo-805" :
                      "bg-blue-950/20 text-blue-400 border-blue-900/30"
                    }`}>
                      {conv.status === "active_agent" ? "operator" : conv.status === "solved" ? "ROZWIĄZANE" : "AI BOT"}
                    </span>

                    {/* Insufficient info badge */}
                    {conv.insufficientInfo && conv.status !== "active_agent" && (
                      <span className="text-[9px] px-1.5 py-0.5 rounded border border-red-500/40 bg-red-950/20 text-red-400 font-bold animate-pulse">
                        ⚠️ BRAK INFO W BAZIE
                      </span>
                    )}
                  </div>
                </button>
              );
            })
          )}
        </div>
      </div>

      {/* Mid & Right - Chat dialogue and AI insights */}
      {selectedConv ? (
        <div className="lg:col-span-2 grid grid-cols-1 md:grid-cols-12 gap-4 h-full">
          
          {/* Chat dialog body  - 7 cols */}
          <div className="md:col-span-12 lg:col-span-7 bg-[#0f1115] border border-white/10 rounded-xl flex flex-col overflow-hidden h-full">
            {/* Thread Header */}
            <div className="p-4 border-b border-white/10 bg-[#0a0b0d] flex items-center justify-between">
              <div>
                <h3 className="font-semibold text-sm text-white">{t.chatWithClient} {selectedConv.userName}</h3>
                <span className="text-[10px] text-gray-550 block">{selectedConv.userEmail}</span>
              </div>
              <div className="flex items-center gap-1 flex-wrap">
                <button
                  onClick={handleToggleTakeover}
                  title={selectedConv.status === "active_agent" ? "Włącz bota" : "Zatrzymać bota (Przejmij czat)"}
                  className={`p-1.5 rounded-md border text-xs font-semibold flex items-center gap-1 cursor-pointer ${
                    selectedConv.status === "active_agent" 
                      ? "bg-indigo-600/20 border-indigo-500/40 text-indigo-455 hover:bg-indigo-600/30 text-indigo-200"
                      : "bg-white/5 hover:bg-white/10 text-gray-300 border-white/10"
                  }`}
                >
                  <ArrowRightLeft className="w-3.5 h-3.5 text-indigo-455" />
                  <span className="hidden sm:inline">
                    {selectedConv.status === "active_agent" ? (language === "pl" ? "Włącz Bota AI" : "Enable Bot AI") : (language === "pl" ? "Wstrzymaj Bota AI" : "Stop Bot AI")}
                  </span>
                </button>

                <button
                  onClick={handleToggleSolved}
                  className={`p-1.5 rounded-md border text-xs font-semibold flex items-center gap-1 cursor-pointer ${
                    selectedConv.status === "solved"
                      ? "bg-[#16191f] border-white/10 text-gray-300"
                      : "bg-green-600/15 border-green-500/35 text-green-400 hover:bg-green-600/20"
                  }`}
                >
                  <CheckCircle className="w-3.5 h-3.5 text-green-405" />
                  <span className="hidden sm:inline">
                    {selectedConv.status === "solved" ? "Otwórz ponownie" : "Zamknij proces"}
                  </span>
                </button>
              </div>
            </div>

            {/* Insufficient Knowledge Warning Banner */}
            {selectedConv.status !== "active_agent" && selectedConv.insufficientInfo && (
              <div className="bg-red-950/40 border-b border-red-500/25 p-3.5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 animate-in fade-in slide-in-from-top-2 duration-300">
                <div className="flex items-start gap-2.5">
                  <span className="text-lg animate-bounce">⚠️</span>
                  <div>
                    <h5 className="text-xs font-bold text-red-300">
                      {language === "pl" ? "Wykryto brak bazy wiedzy!" : "Insufficient Knowledge Base Info!"}
                    </h5>
                    <p className="text-[11px] text-gray-300 leading-normal mt-0.5">
                      {language === "pl" 
                        ? "Czatbot poinformował, że w bazie wiedzy brakuje informacji do rzetelnej odpowiedzi na to pytanie. Przejmij rozmowę lub zatrzymaj bota, aby odpowiedzieć klientowi." 
                        : "The AI agent flagged that it lacks knowledge base references to safely reply. Stop the bot to take manual control."}
                    </p>
                  </div>
                </div>
                <button
                  onClick={() => {
                    onUpdateConversation({
                      ...selectedConv,
                      status: "active_agent",
                      lastUpdated: new Date().toISOString(),
                    });
                  }}
                  className="bg-red-700 hover:bg-red-600 active:scale-95 text-xs text-white px-3 py-1.5 rounded-lg font-semibold flex items-center gap-1 transition-all cursor-pointer shadow-md flex-shrink-0"
                >
                  {language === "pl" ? "Wstrzymaj bota i przejmij" : "Stop bot & Take over"}
                </button>
              </div>
            )}

            {/* Bot Paused Info Bar */}
            {selectedConv.status === "active_agent" && (
              <div className="bg-indigo-950/45 border-b border-indigo-500/20 p-3 flex items-center gap-2.5 select-none">
                <span className="flex h-2 w-2 relative">
                  <span className="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
                  <span className="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"></span>
                </span>
                <p className="text-xs text-indigo-300">
                  {language === "pl" 
                    ? "🤖 Bot AI jest wstrzymany. Rozmawiasz bezpośrednio z klientem." 
                    : "🤖 AI Bot is paused. You are currently chatting directly with the client."}
                </p>
              </div>
            )}

            {/* Messages Thread list */}
            <div className="flex-1 overflow-y-auto p-4 space-y-3.5">
              {selectedConv.messages.map((msg) => {
                const isUser = msg.sender === "user";
                const isBot = msg.sender === "bot";
                const isAgent = msg.sender === "agent";

                return (
                  <div
                    key={msg.id}
                    className={`flex ${isUser ? "justify-start" : "justify-end"}`}
                  >
                    <div className="max-w-[85%]">
                      <div className="flex items-center gap-1.5 mb-0.5 px-0.5">
                        <span className="text-[10px] font-bold text-gray-550">
                          {isUser ? selectedConv.userName : isAgent ? "TY (Konsultant)" : "AI Bot"}
                        </span>
                        <span className="text-[9px] text-gray-600 font-mono">
                          {msg.timestamp}
                        </span>
                      </div>
                      
                      <div className={`rounded-xl px-3.5 py-2 text-xs leading-relaxed border ${
                        isUser ? "bg-[#16191f] border-white/5 text-gray-100" :
                        isAgent ? "bg-indigo-950/30 border-indigo-500/25 text-indigo-200" :
                        "bg-[#0f1115] border-white/10 text-indigo-100"
                      }`}>
                        {msg.text}
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>

            {/* Input Form for Operator */}
            <form onSubmit={handleSendMessage} className="p-3 border-t border-white/10 bg-[#0a0b0d] flex gap-2">
              <input
                type="text"
                value={inputText}
                onChange={(e) => setInputText(e.target.value)}
                placeholder={t.writeMessagePlaceholder}
                className="flex-1 bg-[#16191f] border border-white/10 rounded-lg py-2 px-3 text-xs text-gray-200 focus:outline-none focus:border-indigo-505 placeholder-gray-500"
              />
              <button
                type="submit"
                disabled={!inputText.trim()}
                className="bg-indigo-600 hover:bg-indigo-500 disabled:bg-[#16191f] text-white font-medium rounded-lg text-xs px-4 flex items-center gap-1.5 transition-colors cursor-pointer"
              >
                <Send className="w-3.5 h-3.5" />
                <span>{t.sendMessage}</span>
              </button>
            </form>
          </div>

          {/* AI Insights - 5 cols */}
          <div className="md:col-span-12 lg:col-span-5 flex flex-col gap-4 h-full overflow-y-auto">
            
            {/* Classification Analysis Card */}
            <div className="bg-[#16191f] border border-white/5 rounded-xl p-4 shadow-xl flex flex-col gap-3">
              <div className="flex items-center gap-2 pb-2 border-b border-white/5">
                <Sparkles className="w-4 h-4 text-indigo-400 animate-pulse" />
                <h4 className="text-xs font-bold text-white uppercase tracking-wider">{t.aiAnalysis}</h4>
              </div>

              {/* Urgency */}
              <div>
                <span className="text-[10px] text-gray-400 font-semibold block uppercase tracking-wide mb-1">
                  {t.problemUrgency}
                </span>
                <div className="flex items-center gap-2">
                  <span className={`text-xs px-2.5 py-0.5 rounded border font-bold uppercase tracking-wider ${getUrgencyBadgeColor(selectedConv.urgency)}`}>
                    {getUrgencyNamePlEn(selectedConv.urgency)}
                  </span>
                  <span className="text-[10px] font-bold text-gray-500">
                    ({t.calculatedUrgency})
                  </span>
                </div>
                {selectedConv.urgencyReason && (
                  <p className="text-[11px] text-gray-300 italic mt-1.5 leading-relaxed bg-[#0f1115] p-2 rounded border border-white/5">
                    💡 "{selectedConv.urgencyReason}"
                  </p>
                )}
              </div>

              {/* Sentiment */}
              <div>
                <span className="text-[10px] text-gray-400 font-semibold block uppercase tracking-wide mb-1">
                  {t.detectedSentiment}
                </span>
                <div className="text-xs bg-[#0f1115] p-2 rounded inline-block font-semibold">
                  {getSentimentIcon(selectedConv.sentiment)}
                </div>
              </div>

              {/* Extracted Category */}
              {selectedConv.category && (
                <div>
                  <span className="text-[10px] text-gray-400 font-semibold block uppercase tracking-wide mb-0.5">
                    {t.analysisCategory}
                  </span>
                  <p className="text-xs text-indigo-350 font-bold bg-[#0f1115] py-1 px-2.5 border border-white/5 rounded-md inline-block">
                    🏷️ {selectedConv.category}
                  </p>
                </div>
              )}
            </div>

            {/* AI suggestions action buttons (Co-Pilot) */}
            <div className="bg-[#16191f] border border-white/5 rounded-xl p-4 shadow-xl">
              <div className="flex items-center gap-2 pb-2 border-b border-white/5 mb-3">
                <Smile className="w-4 h-4 text-indigo-455 text-indigo-450" />
                <h4 className="text-xs font-bold text-gray-200 uppercase tracking-widest">{t.agentCopilotSuggestions}</h4>
              </div>

              {selectedConv.suggestions && selectedConv.suggestions.length > 0 ? (
                <div className="space-y-2">
                  <p className="text-[10px] text-gray-405">
                    {language === "pl" ? "Generowane w locie przez model Gemini na podstawie zapytania i bazy wiedzy:" : "Dynamically generated by Gemini models mapping company knowledge context:"}
                  </p>
                  
                  {selectedConv.suggestions.map((sug, idx) => (
                    <div key={idx} className="bg-[#0f1115] hover:bg-[#0a0b0d] border border-white/5 p-2 rounded-lg relative group transition-all text-left">
                      <p className="text-xs text-gray-100 pr-12 leading-normal">
                        {sug}
                      </p>
                      
                      <button
                        onClick={() => handleApplySuggestion(sug)}
                        className="absolute right-2 top-2 text-[10px] font-semibold bg-indigo-650/10 hover:bg-indigo-600 border border-indigo-500/20 hover:border-indigo-500 text-indigo-400 hover:text-white rounded px-2 py-0.5 block transition-all opacity-90 group-hover:opacity-100 cursor-pointer"
                      >
                        {language === "pl" ? "Wstaw" : "Use"}
                      </button>
                    </div>
                  ))}
                </div>
              ) : (
                <div className="text-center py-6 text-gray-500 text-xs">
                  {language === "pl" 
                    ? "Napisz wiadomość na czacie, aby AI wygenerowało inteligentne propozycje podpowiedzi." 
                    : "Generate responses from the Client Widget first to auto-gather Co-Pilot suggestions."}
                </div>
              )}
            </div>

          </div>

        </div>
      ) : (
        <div className="lg:col-span-2 bg-[#16191f] border border-white/5 rounded-xl flex items-center justify-center p-8 text-center text-gray-500 text-sm">
          <div className="flex flex-col items-center gap-3">
            <MessageSquare className="w-12 h-12 text-[#2a2d35] animate-bounce" />
            <p>{language === "pl" ? "Wybierz konwersację z listy po lewej, aby rozpocząć proces analizy." : "Select a customer conversation from the list to display active support panel."}</p>
          </div>
        </div>
      )}

    </div>
  );
}
